<script>
  function toggle(el) {
    el.classList.toggle('checked');
    updateResult();
  }

  function updateResult() {
    const items = document.querySelectorAll('.check-item');
    let t1 = 0, t2 = 0, total = 0;

    items.forEach(item => {
      if (item.classList.contains('checked')) {
        total++;
        if (item.dataset.track === '1') t1++;
        else t2++;
      }
    });

    document.getElementById('score-t1').textContent = t1;
    document.getElementById('score-t2').textContent = t2;

    const t1Total = document.querySelectorAll('.check-item[data-track="1"]').length;
    const t2Total = document.querySelectorAll('.check-item[data-track="2"]').length;
    const allTotal = t1Total + t2Total;

    const t1Pct = allTotal > 0 ? (t1 / allTotal) * 100 : 0;
    const t2Pct = allTotal > 0 ? (t2 / allTotal) * 100 : 0;
    document.getElementById('bar-t1').style.width = t1Pct + '%';
    document.getElementById('bar-t2').style.width = t2Pct + '%';

    const empty = document.getElementById('empty-state');
    const r1 = document.getElementById('result-t1');
    const r2 = document.getElementById('result-t2');
    const tie = document.getElementById('result-tie');

    r1.classList.remove('show');
    r2.classList.remove('show');
    tie.classList.remove('show');

    const note = document.getElementById('result-note');

    if (total === 0) {
      empty.style.display = 'block';
      note.style.display = 'none';
      return;
    }

    empty.style.display = 'none';
    note.style.display = total <= 2 ? 'block' : 'none';

    const diff = Math.abs(t1 - t2);

    if (diff <= 1) {
      tie.classList.add('show');
    } else if (t1 > t2) {
      const pct = Math.round((t1 / total) * 100);
      document.getElementById('result-t1-text').innerHTML =
        '분석 · 보고 성향 <strong>' + pct + '%</strong> · 체크한 ' + total + '개 중 ' + t1 + '개가 Track A 항목이에요.';
      r1.classList.add('show');
    } else {
      const pct = Math.round((t2 / total) * 100);
      document.getElementById('result-t2-text').innerHTML =
        '프로그램 빌드 성향 <strong>' + pct + '%</strong> · 체크한 ' + total + '개 중 ' + t2 + '개가 Track B 항목이에요.';
      r2.classList.add('show');
    }
  }

  function resetAll() {
    document.querySelectorAll('.check-item').forEach(item => {
      item.classList.remove('checked');
    });
    updateResult();
    document.querySelector('.checklist').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>

</body>
</html>
